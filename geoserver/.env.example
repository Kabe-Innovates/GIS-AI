# Copy this file to .env and replace secrets before first run.

# Host port for GeoServer web UI and OGC services
GEOSERVER_PORT=8080

# GeoServer admin bootstrap credentials (change for your machine)
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=change_me_now

# JVM memory tuning for laptop-class hackathon machines
INITIAL_MEMORY=512M
MAXIMUM_MEMORY=2G

# Layer contract used by validation script and app integration
GEOSERVER_WORKSPACE=geonex
GEOSERVER_LAYER=tn_accidents_500
